{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://neostack.dev/schemas/extension-ui.schema.json",
  "title": "NeoStack Extension UI Metadata",
  "description": "Human-readable metadata for NeoStack extension cards in the editor and cloud catalog.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "domain",
    "domainLabel",
    "sortOrder",
    "agentSummary",
    "enablesAgentTo",
    "whenToEnable",
    "isRecommended"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "domain": {
      "type": "string",
      "enum": [
        "recommended",
        "animation",
        "ai",
        "vfx",
        "world",
        "input",
        "pipeline"
      ]
    },
    "domainLabel": {
      "type": "string",
      "minLength": 1
    },
    "sortOrder": {
      "type": "integer",
      "minimum": 0
    },
    "agentSummary": {
      "type": "string",
      "minLength": 1
    },
    "enablesAgentTo": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "whenToEnable": {
      "type": "string",
      "minLength": 1
    },
    "isRecommended": {
      "type": "boolean"
    },
    "isBetaVersion": {
      "type": "boolean"
    },
    "isExperimentalVersion": {
      "type": "boolean"
    }
  }
}
